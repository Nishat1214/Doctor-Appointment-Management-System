@{
    ViewData["Title"] = "Doctor/Patient Page";
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>@ViewData["Title"]</title>
 
    <style>
        body {
            background-image: url('/images/doctors-background.jpg'); /* Update path if needed */
            background-size: cover;
            background-repeat: no-repeat;
            background-attachment: fixed;
            font-family: Arial, sans-serif;
            color: white;
            margin: 0;
        }

        .navbar {
            background-color: #FFC1CC; /* Pink background */
            display: flex;
            justify-content: space-around;
            padding: 20px;
            box-shadow: 0 2px 8px rgba(0, 0, 0, 0.2);
            position: relative;
            z-index: 1;
        }

            .navbar a {
                text-decoration: none;
                color: #0000EE; /* Blue links */
                font-weight: bold;
                font-size: 20px;
            }

        .content {
            padding: 60px;
            background-color: rgba(0, 0, 0, 0.3); /* Semi-transparent background */
            margin: 40px auto;
            width: 80%;
            border-radius: 10px;
            position: relative;
            z-index: 1;
        }
    </style>
</head>
<body>
    <div class="navbar">
        <a asp-controller="Home" asp-action="DoctorPatient">HOME</a>
        <a asp-controller="Doctor" asp-action="Login">DOCTOR LOGIN</a>
  
        <a asp-controller="Appointment" asp-action="SelectSpeciality">APPOINTMENT</a>
    </div>
    <div class="content">
        <h1>DOCTOR/PATIENT Portal</h1>
        <p>Welcome to the Doctor/Patient section of our healthcare application. This portal allows doctors and patients to manage appointments, view reports, and access other healthcare services.</p>
        <p>Current time: @DateTime.Now.ToString("hh:mm tt zzz") on @DateTime.Now.ToString("dddd, MMMM dd, yyyy")</p>
        <p>
            <a href="@Url.Action("Appointments", "Doctor")" style="color: #0000EE; text-decoration: none; font-weight: bold;">
                View Doctor Appointments
            </a>
        </p>
        <p>
            <a href="@Url.Action("Login", "Doctor")" style="color: #0000EE; text-decoration: none; font-weight: bold;">
                Doctor Login
            </a>
        </p>
        <p>
            <a href="@Url.Action("Index", "Patient")" style="color: #0000EE; text-decoration: none; font-weight: bold;">
                Patient Portal
            </a>
        </p>
    </div>
</body>
</html>