@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Appointment Confirmation</title>
    <style>
        body {
            margin: 0;
            font-family: Arial, sans-serif;
            background-color: #f4f4f9;
            color: #333;
        }

        .container {
            max-width: 600px;
            margin: 0 auto;
            padding: 20px;
            text-align: center;
        }

        h1 {
            color: #2c3e50;
            margin-bottom: 20px;
        }

        p {
            font-size: 18px;
            color: #28a745;
        }

        .home-link {
            display: inline-block;
            margin-top: 20px;
            padding: 10px 20px;
            background-color: #007bff;
            color: white;
            text-decoration: none;
            border-radius: 4px;
            font-weight: bold;
            transition: background-color 0.3s;
        }

        .navbar {
            background-color: #FFC1CC;
            display: flex;
            justify-content: space-around;
            padding: 20px;
            box-shadow: 0 2px 8px rgba(0, 0, 0, 0.2);
            position: relative;
            z-index: 1;
        }


            .navbar a {
                text-decoration: none;
                color: #0000EE; /* Blue links */
                font-weight: bold;
                font-size: 20px;
            }

            .home-link:hover {
                background-color: #0056b3;
            }
    </style>
</head>
<body>
    <div class="navbar">
        <a asp-controller="Home" asp-action="DoctorPatient">HOME</a>
  
        <a asp-controller="Appointment" asp-action="SelectSpeciality">APPOINTMENT</a>
    </div>

    <div class="container">
        <h1>Appointment Confirmation</h1>
        <p>Your appointment has been successfully created!</p>
       
    </div>
</body>
</html>