@model IEnumerable<Test1.Models.Appointment>

@{
    ViewData["Title"] = "Doctor Appointments";
    Layout = null;

    var doctorId = ViewBag.DoctorId ?? 0; // Assumes DoctorId is passed via ViewBag
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <title>@ViewData["Title"]</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <style>
        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            margin: 0;
            padding: 0;
            background-image: url('/images/background.jpg');
            background-size: cover;
            background-repeat: no-repeat;
            background-attachment: fixed;
            color: #333;
        }

        .header {
            background-color: #FFC1CC;
            padding: 20px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .buttons a,
        .buttons button {
            background-color: #FFC1CC;
            color: #333;
            padding: 10px 20px;
            border: none;
            border-radius: 5px;
            text-decoration: none;
            font-size: 16px;
            font-weight: bold;
            cursor: pointer;
            margin-right: 10px;
            transition: background-color 0.3s;
        }

        .buttons button {
            background-color: #0066CC;
            color: white;
        }

            .buttons a:hover,
            .buttons button:hover {
                background-color: #FFB6C1;
            }

            .buttons button:hover {
                background-color: #0052A3;
            }

        .title {
            font-size: 24px;
            font-weight: bold;
        }

        .content {
            background-color: rgba(255, 255, 255, 0.95);
            margin: 50px auto;
            padding: 30px;
            max-width: 1000px;
            border-radius: 10px;
            box-shadow: 0 5px 20px rgba(0,0,0,0.2);
        }

        h1 {
            text-align: center;
            color: navy;
            margin-bottom: 20px;
        }

        p {
            text-align: center;
            font-size: 16px;
        }

        table {
            width: 100%;
            border-collapse: collapse;
            margin-top: 25px;
        }

        th, td {
            padding: 12px;
            border: 1px solid #ccc;
            text-align: center;
        }

        th {
            background-color: navy;
            color: white;
        }

        tr:nth-child(even) {
            background-color: #f4f4f4;
        }

        tr:nth-child(odd) {
            background-color: #ffffff;
        }

        a.action-link {
            color: crimson;
            font-weight: bold;
            text-decoration: none;
        }

            a.action-link:hover {
                text-decoration: underline;
            }

        .no-data {
            margin-top: 30px;
            text-align: center;
            color: #777;
            font-size: 18px;
        }

        .back-button {
            display: inline-block;
            margin-top: 20px;
            padding: 8px 16px;
            background-color: navy;
            color: white;
            border-radius: 5px;
            text-decoration: none;
            font-weight: bold;
        }

            .back-button:hover {
                background-color: darkblue;
            }
    </style>
</head>
<body>
    <!-- Dashboard Header -->
    <div class="header">
        <div class="buttons">
            <a asp-controller="Doctor" asp-action="Appointments" asp-route-doctorId="@doctorId">VIEW APPOINTMENT</a>
            <a asp-controller="Doctor" asp-action="Update" asp-route-id="@doctorId">UPDATE</a>
            <form asp-action="Index" asp-controller="Home" method="post" style="display:inline;">
                @Html.AntiForgeryToken()
                <button type="submit">Logout</button>
            </form>
        </div>
      
    </div>

    <!-- Appointment Info -->
    <div class="content">
        <h1>APPOINTMENT INFORMATION</h1>
        <p>Below is a list of your approved appointments for Doctor ID: <strong>@doctorId</strong></p>

        @if (Model.Any())
        {
            <table>
                <thead>
                    <tr>
                        <th>Patient Name</th>
                        <th>Appointment Date</th>
                        <th>Status</th>
                        <th>Notes</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var appointment in Model)
                    {
                        <tr>
                            <td>@appointment.Patient?.Name</td>
                            <td>@appointment.AppointmentDate.ToString("dd MMM yyyy hh:mm tt")</td>
                            <td>@appointment.Status</td>
                            <td>@appointment.Notes</td>
                            <td>
                                <a asp-action="DeleteAppointment" asp-route-id="@appointment.Id" asp-route-doctorId="@doctorId" class="action-link" onclick="return confirm('Are you sure you want to delete this appointment?')">Delete</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        else
        {
            <div class="no-data">No appointments found</div>
        }

    
    </div>
</body>
</html>
