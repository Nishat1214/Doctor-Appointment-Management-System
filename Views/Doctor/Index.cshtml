@model IEnumerable<Test1.Models.Doctor>

@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Doctors - Index</title>
    <style>
        body {
            background-image: url('/images/your-background.jpg');
            background-size: cover;
            background-repeat: no-repeat;
            background-attachment: fixed;
            font-family: Arial, sans-serif;
            margin: 0;
            padding: 20px;
        }

        .container {
            max-width: 1200px;
            margin: 0 auto;
            background-color: rgba(255, 255, 255, 0.95);
            padding: 20px;
            border-radius: 10px;
        }

        h1 {
            text-align: center;
            color: #2c2c2c;
            margin-bottom: 20px;
        }

        .create-link {
            display: inline-block;
            margin-bottom: 20px;
            padding: 10px 20px;
            background-color: navy;
            color: white;
            text-decoration: none;
            border-radius: 4px;
            font-weight: bold;
        }

            .create-link:hover {
                background-color: darkblue;
            }

        .search-bar {
            margin-bottom: 20px;
            display: flex;
            align-items: center;
        }

            .search-bar label {
                font-weight: bold;
                margin-right: 10px;
            }

            .search-bar input[type="text"] {
                padding: 5px;
                width: 250px;
                border: 1px solid #ccc;
                border-radius: 4px;
            }

            .search-bar button {
                margin-left: 10px;
                padding: 5px 10px;
                background-color: #ddd;
                border: none;
                cursor: pointer;
                border-radius: 4px;
            }

        table {
            width: 100%;
            border-collapse: collapse;
            margin-top: 10px;
        }

        th {
            background-color: #2c2c2c;
            color: white;
            padding: 10px;
            text-align: left;
        }

        tr:nth-child(even) {
            background-color: #fefefe;
        }

        tr:nth-child(odd) {
            background-color: #ffc0cb;
        }

        td {
            padding: 10px;
        }

        .action-links a {
            display: inline-block;
            margin-right: 5px;
            background-color: navy;
            color: white;
            padding: 5px 10px;
            text-decoration: none;
            border-radius: 4px;
        }

            .action-links a:hover {
                background-color: darkblue;
            }

            .action-links a.delete {
                background-color: crimson;
            }

        .nav-container {
            background-color: #FFC1CC; /* Pink background */
            padding: 20px;
            text-align: center;
            position: relative;
            z-index: 1;
        }

            .nav-container a {
                display: inline-block;
                background-color: #ccc; /* Default gray background */
                color: #000;
                padding: 10px 20px;
                margin: 0 10px;
                border-radius: 5px;
                text-decoration: none;
                font-size: 16px;
                font-weight: bold;
            }

                .nav-container a:hover {
                    background-color: #bbb; /* Slightly darker gray on hover */
                }

                .nav-container a.logout {
                    background-color: #FF3333; /* Red background for LOGOUT */
                    color: white;
                }

                    .nav-container a.logout:hover {
                        background-color: #CC0000; /* Darker red on hover */
                    }

                .action-links a.delete:hover {
                    background-color: darkred;
                }

        .no-data {
            text-align: center;
            padding: 20px;
            color: #666;
            font-style: italic;
        }
    </style>
</head>
<body>
    <div class="nav-container">
        <a href="@Url.Action("Index", "Doctor")">VIEW DOCTOR</a>
        <a href="@Url.Action("Create", "Doctor")">ADD DOCTOR</a>
        <a href="@Url.Action("Index", "Appointment")">APPROVAL</a>
        <a href="@Url.Action("Index", "Home")" class="logout">LOGOUT</a>
    </div>
    <div class="container">
        <h1>Doctors List</h1>

      

        @if (Model.Any())
        {
            <table>
                <thead>
                    <tr>
                        <th>@Html.DisplayNameFor(model => model.Name)</th>
                        <th>@Html.DisplayNameFor(model => model.Email)</th>
                      
                        <th>Specialty</th>
                       
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@Html.DisplayFor(modelItem => item.Name)</td>
                            <td>@Html.DisplayFor(modelItem => item.Email)</td>
                          
                            <td>@item.Specialty?.Name</td>
                          
                            <td class="action-links">
                                <a asp-action="Edit" asp-route-id="@item.Id">Edit</a>
                                <a asp-action="Details" asp-route-id="@item.Id">Details</a>
                                <a asp-action="Delete" asp-route-id="@item.Id" class="delete" onclick="return confirm('Are you sure you want to delete this doctor?')">Delete</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        else
        {
            <p class="no-data">No doctors found.</p>
        }
    </div>
</body>
</html>
