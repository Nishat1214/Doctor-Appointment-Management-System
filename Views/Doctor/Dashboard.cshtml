@{
    ViewData["Title"] = "Doctor Dashboard";
    Layout = null;

    var doctorId = TempData["DoctorId"] != null ? (int)TempData["DoctorId"] : 0;
    TempData.Keep("DoctorId"); // Keep the value for future requests
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <style>
        body {
            margin: 0;
            font-family: Arial, sans-serif;
            position: relative;
            min-height: 100vh;
            color: #333;
        }

        .header {
            background-color: #FFC1CC;
            padding: 20px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            z-index: 1;
        }

        .buttons a,
        .buttons button {
            background-color: #FFC1CC;
            color: #333;
            padding: 10px 20px;
            border: none;
            border-radius: 5px;
            text-decoration: none;
            font-size: 16px;
            font-weight: bold;
            cursor: pointer;
            margin-right: 10px;
            transition: background-color 0.3s;
        }

            .buttons a:hover,
            .buttons button:hover {
                background-color: #FFB6C1;
            }

        .buttons button {
            background-color: #0066CC;
            color: white;
        }

            .buttons button:hover {
                background-color: #0052A3;
            }

        .title {
            font-size: 24px;
            font-weight: bold;
            color: #333;
        }

        .background-image {
            width: 100%;
            height: auto;
            position: absolute;
            top: 0;
            left: 0;
            z-index: -1;
            opacity: 0.1; /* Add this for better contrast */
        }
    </style>
</head>
<body>
    <div class="header">
        <div class="buttons">
            <a asp-controller="Doctor" asp-action="Appointments" asp-route-doctorId="@doctorId">VIEW APPOINTMENT</a>
            <a asp-controller="Doctor" asp-action="Update" asp-route-id="@doctorId">UPDATE</a>
            <form asp-action="Index" asp-controller="Home" method="post" style="display: inline;">
                @Html.AntiForgeryToken()
                <button type="submit">Logout</button>
            </form>
        </div>
    
    </div>

    <img src="~/images/doctors-background.jpg" alt="Doctors background" class="background-image" />
</body>
</html>