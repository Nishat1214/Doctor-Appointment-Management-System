@model Test1.Models.Doctor

@{
    ViewData["Title"] = "Edit Doctor";
    Layout = "~/Views/Shared/_Layout.cshtml"; // Remove this line if you intentionally want no layout
}
<style>
    body {
        margin: 0;
        font-family: Arial, sans-serif;
        position: relative;
        min-height: 100vh; /* Ensure body takes full viewport height */
    }

    .header {
        background-color: #FFC1CC; /* Pink background */
        padding: 20px;
        text-align: center;
        position: relative;
        z-index: 1;
    }

        .header h1 {
            margin: 0;
            font-size: 24px;
            color: #333;
        }

    .nav-container {
        background-color: #FFC1CC; /* Pink background */
        padding: 20px;
        text-align: center;
        position: relative;
        z-index: 1;
    }

        .nav-container a {
            display: inline-block;
            background-color: #ccc; /* Default gray background */
            color: #000;
            padding: 10px 20px;
            margin: 0 10px;
            border-radius: 5px;
            text-decoration: none;
            font-size: 16px;
            font-weight: bold;
        }

            .nav-container a:hover {
                background-color: #bbb; /* Slightly darker gray on hover */
            }

            .nav-container a.logout {
                background-color: #FF3333; /* Red background for LOGOUT */
                color: white;
            }

                .nav-container a.logout:hover {
                    background-color: #CC0000; /* Darker red on hover */
                }

    .background-image {
        width: 100%;
        height: auto;
        position: absolute;
        top: 0;
        left: 0;
        z-index: -1;
    }
</style>
<div class="nav-container">
    <a href="@Url.Action("Index", "Doctor")">VIEW DOCTOR</a>
    <a href="@Url.Action("Create", "Doctor")">ADD DOCTOR</a>
    <a href="@Url.Action("Index", "Appointment")">APPROVAL</a>
    <a href="@Url.Action("Index", "Home")" class="logout">LOGOUT</a>
</div>

<h1 class="text-center">Edit Doctor Information</h1>
<hr />

<div class="row justify-content-center">
    <div class="col-md-6">
        <form asp-action="Edit">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <input type="hidden" asp-for="Id" />

            <div class="form-group mb-3">
                <label asp-for="Name" class="form-label"></label>
                <input asp-for="Name" class="form-control" />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Email" class="form-label"></label>
                <input asp-for="Email" class="form-control" type="email" />
                <span asp-validation-for="Email" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Password" class="form-label"></label>
                <input asp-for="Password" class="form-control" type="password" />
                <span asp-validation-for="Password" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="SpecialtyId" class="form-label"></label>
                <select asp-for="SpecialtyId" class="form-control" asp-items="ViewBag.SpecialtyId">
                    <option value="">-- Select Specialty --</option>
                </select>
                <span asp-validation-for="SpecialtyId" class="text-danger"></span>
            </div>

            <div class="form-check mb-3">
                <input class="form-check-input" asp-for="IsApproved" />
                <label class="form-check-label" asp-for="IsApproved"></label>
            </div>

            <div class="form-group d-flex justify-content-between">
                <input type="submit" value="Save" class="btn btn-primary" />
                <a asp-action="Index" class="btn btn-secondary">Back to List</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
